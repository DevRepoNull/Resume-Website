@model List<EducationViewModel>

<!-- Experience -->
<div class="section">
    <h2 class="title title--h2"><i class="fas fa-graduation-cap"></i> تحصیلات</h2>
    <div class="timeline">
        
        @foreach (EducationViewModel item in Model)
        {
            <!-- Item -->
            <article class="timeline__item">
                <h5 class="title title--h3 timeline__title">@item.Title</h5>
                <span class="timeline__period">@item.EndDate - @item.StartDate</span>
                <p class="timeline__description">@item.Description</p>
            </article>
        }

    </div>
</div>