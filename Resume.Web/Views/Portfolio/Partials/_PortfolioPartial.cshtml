@model List<PortfolioViewModel>

<!-- Content -->
<div class="gallery-grid js-grid js-filter-container">
    <div class="gutter-sizer"></div>
    <!-- Item 1 -->
    @foreach (PortfolioViewModel item in Model)
    {
        <figure class="gallery-grid__item category-@item.PortfolioCategoryLatinTitle">
            <div class="gallery-grid__image-wrap">
                <img class="gallery-grid__image cover lazyload" src="@($"{FilePaths.Portfolio}{item.Image}")"
                     data-zoom="" alt="@item.AltImage">
            </div>
            <figcaption class="gallery-grid__caption">
                <h4 class="title title--h4 gallery-grid__title"><a
                        href="@(!string.IsNullOrWhiteSpace(item.Link) ? item.Link : "#")">@item.Title</a></h4>
                <span class="gallery-grid__category">@item.PortfolioCategoryLatinTitle</span>
            </figcaption>
        </figure>
    }
</div>