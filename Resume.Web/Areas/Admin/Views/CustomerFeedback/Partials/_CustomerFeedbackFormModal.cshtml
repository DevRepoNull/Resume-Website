@model UpsertCustomerFeedbackViewModel
@{
    bool isCreate = Model.Id == 0 ? true : false;
}

<!-- Start Form -->
<form id="CustomerFeedbackForm" asp-area="Admin" asp-controller="CustomerFeedback" asp-action="SubmitCustomerFeedbackFormModal"
      data-ajax="true" data-ajax-begin="StartLoading" data-ajax-success="CustomerFeedbackFormSubmited">
    <!--Modal Header-->
    <div class="modal-header">
        <h5 class="modal-title">@(isCreate ? "ایجاد" : "ویرایش")</h5>
    </div>

    <!--Modal Body-->
    <div class="modal-body">

        <div class="form-validation">

            <div class="row">
                <div class="col-xl-12">
                    <input type="hidden" asp-for="Avatar" />

                    @if (!isCreate)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="mb-3 row">
                        <label class="col-lg-3 col-form-label" asp-for="Name">
                            @Html.DisplayNameFor(t => Model.Name)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="col-lg-9">
                            <input type="text" class="form-control" asp-for="Name">

                            @* <div class="invalid-feedback">
                                <span asp-validation-for="Title"></span>
                            </div> *@
                            <small>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </small>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-lg-3 col-form-label" asp-for="Description">
                            @Html.DisplayNameFor(t => Model.Description)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="col-lg-9">
                            <input type="text" class="form-control" asp-for="Description">

                            <small>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </small>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-lg-3 col-form-label" asp-for="Order">
                            @Html.DisplayNameFor(t => Model.Order)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="col-lg-9">
                            <input type="number" class="form-control" asp-for="Order">

                            <small>
                                <span asp-validation-for="Order" class="text-danger"></span>
                            </small>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-lg-3 col-form-label" for="image">
                            @Html.DisplayNameFor(t => Model.Avatar)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="col-lg-9">
                            <input type="file" name="image" id="image" class="form-control" />

                            <small>
                                <span asp-validation-for="Avatar" class="text-danger"></span>
                            </small>
                        </div>
                    </div>

                </div>
            </div>

        </div>

    </div>

    <!--Modal Footer-->
    <div class="modal-footer">
        <button type="button" class="btn btn-danger light" data-bs-dismiss="modal">
            بستن
        </button>
        <button type="submit" class="btn @(isCreate ? "btn-success" : "btn-primary")">
            @(isCreate ? "ذخیره اطلاعات" : "ویرایش اطلاعات")
        </button>
    </div>
</form>
<!--End Form-->

<script src="~/panel/custome/CustomerFeedbackAjaxImageUploader.js"></script>